# Kopiraj u .env na serveru i popuni pravim vrijednostima: cp .env.example .env
# .env je u .gitignore i NE ide u git ni u Docker image.

# MSSQL je na HOSTU, pa iz containera idemo preko host.docker.internal.
# databaseName mora odgovarati postojecoj bazi (kod tebe: gamestore).
DB_URL=jdbc:sqlserver://host.docker.internal:1433;databaseName=gamestore;encrypt=true;trustServerCertificate=true
DB_USERNAME=SA
DB_PASSWORD=__promijeni_me__

# Vanjski URL aplikacije (za PayPal redirect linkove). Lokalno ostavi prazno
# pa koristi default http://localhost:8080; na serveru stavi pravu domenu.
APP_BASE_URL=https://tvoja-domena.com

JWT_SECRET=__dugacka-nasumicna-tajna-min-32-znaka__

PAYPAL_CLIENT_ID=__paypal_client_id__
PAYPAL_CLIENT_SECRET=__paypal_client_secret__

MAIL_PASSWORD=__gmail_app_password__

RAWG_API_KEY=__rawg_api_key__
